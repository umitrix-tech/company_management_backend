{
  "name": "company_management_backend",
  "version": "1.0.0",
  "description": "Monorepo root for Company Management",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:backend": "npm run dev -w apps/main-backend",
    "build:backend": "npm run build -w apps/main-backend",
    "dev:signal": "npm run start -w apps/signal-service",
    "start:backend": "npm run start -w apps/main-backend",
    "start:signal": "npm run start -w apps/signal-service",
    "install:all": "npm install",
    "db:migrate": "npx prisma migrate dev --schema=packages/database/prisma/schema.prisma",
    "db:push": "npx prisma db push --schema=packages/database/prisma/schema.prisma",
    "db:generate": "prisma generate --schema=packages/database/prisma/schema.prisma",
    "db:apply": "npm run db:migrate && npm run db:generate",
    "db:formate":"npx primsma format --schema=packages/databases/prisma/schema.prisma",
    "db:seed": "npm run seed -w packages/database"
  },
  "devDependencies": {
    "dotenv": "^17.4.1",
    "nodemon": "^3.1.11",
    "prisma": "^7.6.0"
  },
  "prisma": {
    "schema": "packages/database/prisma/schema.prisma"
  }
}