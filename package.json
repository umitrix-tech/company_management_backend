{
  "name": "company_management_backend",
  "version": "1.0.0",
  "description": "Monorepo root for Company Management",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:backend": "npm run dev -w apps/main-backend",
    "dev:signal": "npm run dev -w apps/signal-service",
    "start:backend": "npm run start -w apps/main-backend",
    "start:signal": "npm run start -w apps/signal-service",
    "install:all": "npm install",
    "prisma:generate": "npx prisma generate --schema packages/database/prisma/schema.prisma",
    "prisma:push": "npx prisma db push --schema packages/database/prisma/schema.prisma"
  },
  "devDependencies": {
    "nodemon": "^3.1.11"
  },
  "prisma": {
    "schema": "packages/database/prisma/schema.prisma"
  }
}
