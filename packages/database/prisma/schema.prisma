// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ComponentType {
  EARNING
  DEDUCTION
}

enum ValueType {
  FIXED
  PERCENTAGE
  FORMULA
}

enum SalaryMode {
  MONTHLY
  DAILY
  HOURLY
}

enum Gender {
  MALE
  FEMALE
  OTHERS
}

enum UserStates {
  ACTIVE
  INACTIVE
}

enum PlanType {
  FREE
  MONTH_PAY
  YEAR_PAY
  SOLD
}

enum ChatType {
  INTERNAL
  CUSTOMER
}

enum MessageSenderType {
  USER
  CUSTOMER
}

enum MessageType {
  TEXT
  IMAGE
  FILE
}

model CompanyConfig {
  id                Int     @id @default(autoincrement())
  isCompanyWentTour Boolean @default(false)
  domain            String  @unique
  themeSetting      Json?   @default("{}")
  downTime          Boolean @default(false)
}

model PlanHistory {
  id         Int      @id @default(autoincrement())
  isActive   Boolean  @default(true)
  version    Decimal  @default(1.0)
  tierOfPlan PlanType
  startDate  DateTime @default(now())
  endDate    DateTime
  companyId  Int
  company    Company  @relation(fields: [companyId], references: [id])

  @@index([companyId])
}

model Company {
  id               Int     @id @default(autoincrement())
  name             String
  address1         String
  address2         String?
  logoUrl          String?
  email            String  @unique
  phone            String  @unique
  gstinNumber      String?
  sacNumber        String?
  panNumber        String?
  esicNumber       String?
  epfNumber        String?
  serviceTaxNumber String?
  websiteLink      String?
  ownerUserId      Int

  documets               String[]                 @default([])
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt
  users                  User[]
  PunchLog               PunchLog[]
  WorkHoursConfiguration WorkHoursConfiguration[]
  particularDateConfigs  ParticularDateConfig[]
  roles                  Role[]
  planHistories          PlanHistory[]
  companyGalleries       CompanyGallery[]
  rolePermissions        RolePermission[]
  timeLine               timeLine[]
  media                  media[]
  policies               policy[]
  Customer               Customer[]
  chats                  Chat[]
  gallery                Gallery[]
  notes                  Notes[]
  aiChatLogs             AiChatLog[]
  CallHistory            CallHistory[]
  PayrollCycle PayrollCycle[]
  SalaryHistory SalaryHistory[]
  PayrollRun PayrollRun[]
  TaxSlab TaxSlab[]
  EmployeeTaxConfig EmployeeTaxConfig[]
  UserWorkConfigHistory UserWorkConfigHistory[]

  salaryTemplates   SalaryTemplate[]
  employeeSalaries  EmployeeSalary[]
  salarySlips       SalarySlip[]  
  attendances       Attendance[]
  salaryAdjustments SalaryAdjustment[]
  loans             Loan[]
  Review            Review[]

  PermissionConfiguration PermissionConfiguration[]
  PermissionRequest PermissionRequest[]
  LeaveRequest LeaveRequest[]
 LeaveConfiguration LeaveConfiguration[]
 LeaveType LeaveType[]
}

model RolePermission {
  id Int @id @default(autoincrement())

  roleId Int
  role   Role @relation(fields: [roleId], references: [id])

  key   String
  label String

  parentId Int?
  parent   RolePermission?  @relation("PermissionTree", fields: [parentId], references: [id])
  children RolePermission[] @relation("PermissionTree")

  access Boolean @default(false)

  companyId Int
  company   Company @relation(fields: [companyId], references: [id])

  @@unique([roleId, key, parentId])
  @@index([companyId])
}

model Role {
  id         Int    @id @default(autoincrement())
  name       String @default("Owner")
  privileges Json   @default("{}")
  users      User[]

  companyId      Int
  company        Company          @relation(fields: [companyId], references: [id])
  RolePermission RolePermission[]

  
  createdAt DateTime? @default(now())
  updatedAt DateTime? @updatedAt

  @@index([companyId])
}

model User {
  id              Int        @id @default(autoincrement())
  name            String
  empCode         String
  adharNumber     String?    @unique
  uanNumber       String?    @unique
  bankAccount     String?
  address         String?
  city            String?
  pinCode         String?
  state           String?
  country         String?
  email           String?    @unique
  bloodGroup      String?
  ifscCode        String?
  gender          Gender?
  epfNumber       String?
  esicNumber      String?
  mobileNumber    String?    @unique
  password        String
  SecondaryMobile String?
  isDetele        Boolean    @default(false)
  status          UserStates @default(ACTIVE)
  backEndStatus   String?
  logoUrl         String?
  backgroundUrl   String?   @default("https://pub-3ea8ee54beac4fd0807ffb8e21903f9d.r2.dev/media/1774767921529-pngtree-painting-of-a-contemporary-building-construction-site-on-white-background-including-image_15883562.jpg")
  documets        String[]   @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // WorkHoursConfigurationId Int?
  companyId                Int?
  company                  Company?          @relation(fields: [companyId], references: [id])
  role                     Role?             @relation(fields: [roleId], references: [id])
  roleId                   Int?
  reportingId              Int?
  manager                  User?             @relation("UserReporting", fields: [reportingId], references: [id])
  reports                  User[]            @relation("UserReporting")
  // PunchLog                 PunchLog         @relation(fields: [punchId], references: [id])
  chatParticipants         ChatParticipant[]
  messages                 Message[]
  messageReads             MessageRead[]
  punchLog   PunchLog[]
  aiChatLogs AiChatLog[]
  callsMade CallHistory[] @relation("Caller")
  callsReceived CallHistory[] @relation("Receiver")
  Review        Review[]
  employeeSalaries EmployeeSalary[]
  
  employeeTaxConfigs EmployeeTaxConfig[]
  UserWorkConfigHistory UserWorkConfigHistory[]
  attendances      Attendance[]
  salarySlips      SalarySlip[]
  adjustments      SalaryAdjustment[]
  loans            Loan[]
  SalaryHistory SalaryHistory[]
  leaveRequests LeaveRequest[]
  approvedLeaves LeaveRequest[] @relation("ApprovedLeaves")
  permissionRequests PermissionRequest[]


  @@unique([companyId, empCode])
  @@unique([companyId, uanNumber])
  @@index([companyId])
}

model OtpStroe {
  id         Int      @id @default(autoincrement())
  email      String
  otp        String
  createdAt  DateTime @default(now())
  expiresAt  DateTime
  isVerified Boolean  @default(false)
}

model CompanyGallery {
  id         Int     @id @default(autoincrement())
  mediaUrl   String
  folderName String
  companyId  Int
  company    Company @relation(fields: [companyId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
}

enum workHoursModal {
  GENERAL_TIME_COVER
  FULL_DAY_TIME_COVER
  SHIFT_TIME_COVER
  DAY_WHAT_EVER_TIME_COVER
}

model BankDetails {
  id          Int    @id @default(autoincrement())
  purpose     String
  bankName    String
  bankAccount String @unique
  ifsc        String @unique
  companyId   Int

  @@index([companyId])
}

model WorkHoursConfiguration {
  id                        Int            @id @default(autoincrement())
  name                      String?
  workHoursModal            workHoursModal @default(GENERAL_TIME_COVER)
  startTime                 String         @default("10:00")
  endTime                   String         @default("17:00")
  workingDurationMinutesMin Int            @default(60)
  workingDurationMintesMax  Int            @default(480)
  shiftTimes                String[]       @default([])
  weeklyOffDays             Int[]          @default([6, 7])

  isActive Boolean @default(true) 
  version Int @default(1) 

  companyId Int
  company   Company @relation(fields: [companyId], references: [id])

  UserWorkConfigHistory UserWorkConfigHistory[]

  @@index([companyId])
}


model UserWorkConfigHistory {
  id Int @id @default(autoincrement())

  userId Int
  user   User @relation(fields: [userId], references: [id])

  companyId Int
  company   Company @relation(fields: [companyId], references: [id])

  workConfigId Int
  workHoursConfiguration   WorkHoursConfiguration @relation(fields: [workConfigId], references: [id])

  effectiveFrom DateTime
  effectiveTo   DateTime?

  createdAt DateTime @default(now())

  @@index([userId, effectiveFrom])
  @@index([userId, companyId])
}


model ParticularDateConfig {
  id          Int      @id @default(autoincrement())
  date        DateTime
  reason      String
  description String

  companyId Int
  company   Company @relation(fields: [companyId], references: [id])

  @@index([companyId])
}

enum PunchLogType {
  IN
  OUT
  JUSTIFY
  PERMISION
  LEAVE
  LOGFIX
}

enum PunchSource {
  WEB
  MOBILE
  BIOMETRIC
}

model PunchLog {
  id        Int          @id @default(autoincrement())
  userId    Int
  punchIn   DateTime?
  punchOut  DateTime?
  remarks   PunchLogType
  updatedBy Int
  punchSource PunchSource @default(WEB)
  companyId Int
  
  company   Company      @relation(fields: [companyId], references: [id])
  user      User    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([companyId])
}

model timeLine {
  id          Int      @id @default(autoincrement())
  date        DateTime
  name        String
  description String?

  roleAccess Int[]

  companyId Int
  company   Company @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@map("timeline")
}

model policy {
  id          Int    @id @default(autoincrement())
  name        String
  description String
  roleAccess  Int[]
  mediaId     Int[]

  companyId Int
  company   Company @relation(fields: [companyId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
}

model media {
  id        Int     @id @default(autoincrement())
  fileName  String
  mimeType  String?
  size      Int
  url       String
  r2Key     String
  type      String
  companyId Int
  company   Company @relation(fields: [companyId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
}

model Customer {
  id        Int     @id @default(autoincrement())
  companyId Int
  name      String
  phone     String?
  email     String?

  createdAt DateTime @default(now())

  company      Company           @relation(fields: [companyId], references: [id])
  participants ChatParticipant[]
  messages     Message[]
  CallHistory  CallHistory[]
  Review       Review[]


  @@index([companyId])
}

model Chat {
  id        Int      @id @default(autoincrement())
  companyId Int
  type      ChatType
  status    String   @default("OPEN") // OPEN | CLOSED
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id])

  participants ChatParticipant[]
  messages     Message[]

  @@index([companyId])
  @@index([companyId, type])
}

model ChatParticipant {
  id        Int @id @default(autoincrement())
  chatId    Int
  companyId Int

  userId     Int?
  customerId Int?

  // used ONLY for customer unread count
  lastReadAt DateTime?

  joinedAt DateTime @default(now())

  chat     Chat      @relation(fields: [chatId], references: [id])
  user     User?     @relation(fields: [userId], references: [id])
  customer Customer? @relation(fields: [customerId], references: [id])

  @@index([chatId, userId])
  @@index([chatId, customerId])
  @@index([companyId])
}

model Message {
  id        Int @id @default(autoincrement())
  chatId    Int
  companyId Int

  senderType       MessageSenderType
  senderUserId     Int?
  senderCustomerId Int?

  messageType MessageType @default(TEXT)
  content     String
  createdAt   DateTime    @default(now())

  chat     Chat      @relation(fields: [chatId], references: [id])
  user     User?     @relation(fields: [senderUserId], references: [id])
  customer Customer? @relation(fields: [senderCustomerId], references: [id])

  reads MessageRead[]

  @@index([chatId])
  @@index([companyId])
  @@index([chatId, createdAt])
}

model MessageRead {
  id        Int      @id @default(autoincrement())
  messageId Int
  userId    Int
  readAt    DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@unique([messageId, userId])
  @@index([userId])
}

model Notes {
  id        Int      @id @default(autoincrement())
  title     String
  content   String
  startDate DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  companyId Int
  company   Company  @relation(fields: [companyId], references: [id])

  @@index([companyId])
}

model Gallery {
  id        Int      @id @default(autoincrement())
  tag       String   @unique
  mediaId   Int
  mediaUrl  String   @default("")
  type      String   @default("DOC")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  companyId Int
  company   Company  @relation(fields: [companyId], references: [id])

  @@index([companyId])
}

model AiChatLog {
  id        Int      @id @default(autoincrement())
  companyId Int
  userId    Int?
  query     String
  response  String   @db.Text
  createdAt DateTime @default(now())

  company   Company  @relation(fields: [companyId], references: [id])
  user      User?    @relation(fields: [userId], references: [id])

  @@index([companyId])
  @@index([companyId, createdAt])
}

enum AttendanceStatus {
  ENTRY
  PRESENT
  ABSENT
  HALF_DAY
  LEAVE
}

enum PayrollStatus {
  OPEN
  PROCESSING
  COMPLETED
  LOCKED
}

enum PayrollRunStatus {
  DRAFT
  FINALIZED
}

enum SalaryChangeType {
  HIKE
  PROMOTION
  CORRECTION
}

model Attendance {
  id Int @id @default(autoincrement())

  userId Int
  user   User @relation(fields: [userId], references: [id])

  companyId Int
  company   Company @relation(fields: [companyId], references: [id])

  date DateTime

  isPresent Boolean @default(true)

  status AttendanceStatus  @default(ABSENT)

  hoursWorked   Float? // for hourly
  overtimeHours Float? // optional

  @@unique([userId, companyId, date])
  @@index([companyId, date])
}

model SalaryTemplate {
  id   Int    @id @default(autoincrement())
  name String

  companyId Int
  company   Company @relation(fields: [companyId], references: [id])

  components       TemplateComponent[]
  employeeSalaries EmployeeSalary[]

  isDeleted Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
}

model TemplateComponent {
  id Int @id @default(autoincrement())

  templateId Int
  template   SalaryTemplate @relation(fields: [templateId], references: [id])

  name String
  code String? // e.g. BASIC, HRA
  

  componentType ComponentType
  valueType     ValueType
  value         Float
  formula       String?
  isTaxable Boolean @default(true)


  order Int?

  @@unique([templateId, name])
  @@index([templateId])
}

model EmployeeSalary {
  id Int @id @default(autoincrement())

  userId Int
  user   User @relation(fields: [userId], references: [id])

  companyId Int
  company   Company @relation(fields: [companyId], references: [id])

  templateId Int?
  template   SalaryTemplate? @relation(fields: [templateId], references: [id])

  salaryMode SalaryMode

  effectiveFrom DateTime
  effectiveTo   DateTime?

  isActive Boolean @default(true)
  isDeleted Boolean @default(false)

  components SalaryComponent[]
  slips      SalarySlip[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, effectiveFrom, effectiveTo])
  @@index([companyId])
}

model SalaryComponent {
  id Int @id @default(autoincrement())

  salaryId Int
  salary   EmployeeSalary @relation(fields: [salaryId], references: [id])

  name String
  code String?

  componentType ComponentType
  valueType     ValueType
  isTaxable Boolean @default(true)

  value   Decimal @db.Decimal(12,2)
  formula String?

  order Int?

  createdAt DateTime @default(now())

  @@unique([salaryId, name])
  @@index([salaryId])
}

model EmployeeTaxConfig {
  id Int @id @default(autoincrement())

  userId Int
  user   User @relation(fields: [userId], references: [id])
  
  taxSlabId Int
  taxSlab   TaxSlab @relation(fields: [taxSlabId], references: [id])

  standardDeduction Boolean @default(true)
  declared80C Float @default(0)

  effectiveFrom DateTime
  effectiveTo   DateTime?

  createdAt DateTime @default(now())
  isDeleted Boolean @default(false)

  companyId Int
  company   Company @relation(fields: [companyId], references: [id])

 @@index([userId, companyId, effectiveFrom])
}

  model TaxSlab {
  id            Int       @id @default(autoincrement())
  financialYear String   
  regime String  
  
  companyId     Int
  company       Company   @relation(fields: [companyId], references: [id])
  isDeleted Boolean @default(false)

  slabs         slabs[]
  EmployeeTaxConfig EmployeeTaxConfig[]



  @@index([companyId, financialYear])
  }

  model slabs {
    id           Int        @id @default(autoincrement())
  
  minIncome    Decimal    @db.Decimal(12, 2)
  maxIncome    Decimal?   @db.Decimal(12, 2) // Nullable for "and above"
  taxRate      Float      // e.g., 0.05 for 5%

  taxSlabId  Int
  TaxSlab    TaxSlab  @relation(fields: [taxSlabId], references: [id], onDelete: Cascade)

  @@index([taxSlabId])
  @@unique([taxSlabId, minIncome, maxIncome])
  }

model PayrollRun {
  id Int @id @default(autoincrement())

  companyId Int

  cycleId Int

  company   Company @relation(fields: [companyId], references: [id])
  cycle     PayrollCycle @relation(fields: [cycleId], references: [id])

  status PayrollRunStatus // DRAFT, FINALIZED
  isLocked Boolean @default(false)
  

  createdAt DateTime @default(now())
  salarySlips SalarySlip[]

  @@index([companyId, cycleId])

}

model SalaryHistory {
  id Int @id @default(autoincrement())

  userId Int
  companyId Int

  company   Company @relation(fields: [companyId], references: [id])
  user   User @relation(fields: [userId], references: [id])


  oldSalary Decimal @db.Decimal(12,2)
  newSalary Decimal @db.Decimal(12,2)

  changeType SalaryChangeType // HIKE, PROMOTION, FIRST_SALARY

  effectiveDate DateTime @default(now())

  createdAt DateTime @default(now())
}

model SalarySlip {
  id Int @id @default(autoincrement())

  userId Int
  user   User @relation(fields: [userId], references: [id])

  salaryId Int
  salary   EmployeeSalary @relation(fields: [salaryId], references: [id])

  cycleId Int
  cycle   PayrollCycle @relation(fields: [cycleId], references: [id])

  isLocked Boolean @default(false)
  grossAmount    Decimal @db.Decimal(12,2)
  totalDeduction Decimal @db.Decimal(12,2)
  netPay         Decimal @db.Decimal(12,2)

  generatedAt DateTime @default(now())

  components SalarySlipComponent[]
  repayments LoanRepayment[]

  companyId Int
  company   Company @relation(fields: [companyId], references: [id])

  payrollRunId Int
  payrollRun   PayrollRun @relation(fields: [payrollRunId], references: [id])

  @@unique([userId, cycleId])
  @@index([companyId, cycleId])
}

model SalarySlipComponent {
  id Int @id @default(autoincrement())

  salarySlipId Int
  salarySlip   SalarySlip @relation(fields: [salarySlipId], references: [id])

  name    String
  code    String?
  formula String?

  componentType ComponentType
  valueType     ValueType
  isTaxable Boolean @default(true)

  value  Decimal @db.Decimal(12,2)
  amount Decimal @db.Decimal(12,2)

  @@index([salarySlipId])
}

model SalaryAdjustment {
  id Int @id @default(autoincrement())

  userId Int
  user   User @relation(fields: [userId], references: [id])

  companyId Int
  company   Company @relation(fields: [companyId], references: [id])

  name String

  componentType ComponentType
  amount        Decimal @db.Decimal(12,2)
  
  month Int
  year  Int

  cycleId Int
  cycle   PayrollCycle @relation(fields: [cycleId], references: [id])


  createdAt DateTime @default(now())

   @@index([userId, month, year])
  @@index([userId, cycleId])
}

model PayrollCycle {
  id Int @id @default(autoincrement())

  name String
  companyId Int
  company   Company @relation(fields: [companyId], references: [id])

  startDate DateTime
  endDate   DateTime
  payoutDate DateTime

  status PayrollStatus @default(OPEN)

  salarySlips SalarySlip[]
  SalaryAdjustment SalaryAdjustment[]
  PayrollRun PayrollRun[]

  


  @@index([companyId, startDate, endDate])
}

model AuditLog {
  id Int @id @default(autoincrement())

  tableName String
  recordId  Int

  userId Int?

  action String

  oldData Json?
  newData Json?

  createdAt DateTime @default(now())
}

model Loan {
  id Int @id @default(autoincrement())

  userId Int
  user   User @relation(fields: [userId], references: [id])

  companyId Int
  company   Company @relation(fields: [companyId], references: [id])

  principalAmount Decimal @db.Decimal(12,2)
  interestRate    Decimal @db.Decimal(12,2) // percentage
  tenureMonths    Int
  olderPaymentId  Int? 

  emiAmount      Decimal @db.Decimal(12,2)
  totalRepayable Decimal @db.Decimal(12,2)

  remainingAmount Decimal @db.Decimal(12,2)
  status          String @default("ACTIVE") 
  disbursedAt DateTime @default(now())

  repayments LoanRepayment[]

  @@index([userId])
  @@index([companyId])
  @@index([userId, status])
}

model LoanRepayment {
  id Int @id @default(autoincrement())

  loanId Int
  loan   Loan @relation(fields: [loanId], references: [id])

  salarySlipId Int?
  salarySlip   SalarySlip? @relation(fields: [salarySlipId], references: [id])

  amount Float
  paidAt DateTime @default(now())

  @@index([loanId])
}

enum CallStatus {
  PENDING
  COMPLETED
  ONGOING
  CANCELLED
}

enum CallType {
  CUSTOMER
  INTERNAL
}

model CallHistory {
  id Int @id @default(autoincrement())

  companyId Int
  company   Company @relation(fields: [companyId], references: [id])

  callerId Int
  caller   User @relation("Caller", fields: [callerId], references: [id])

  receiverId Int
  receiver   User @relation("Receiver", fields: [receiverId], references: [id])

  customerId Int?
  customer   Customer? @relation(fields: [customerId], references: [id])
    
  callType CallType
  callStatus CallStatus
  callDuration Float?
  waitingDuration Float?
  roomId String? @unique
  roomLink String? @unique
  serviceGroupId Int?
  metadata Json? @default("{}")
  callConnectedAt  DateTime?

  review   Review?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Review {
  id Int @id @default(autoincrement())
  rating Int
  comment String?
  
  companyId Int
  company   Company @relation(fields: [companyId], references: [id])
  
  callId Int @unique
  call   CallHistory @relation(fields: [callId], references: [id])
  
  customerId Int?
  customer   Customer? @relation(fields: [customerId], references: [id])
  
  userId Int?
  user   User? @relation(fields: [userId], references: [id])
  
  createdAt DateTime @default(now())
}

enum LeaveRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

model LeaveType {
  id   Int    @id @default(autoincrement())
  name String
  code String @unique

  companyId Int
  company   Company @relation(fields: [companyId], references: [id])

  isPaid    Boolean @default(true)
  isDeleted Boolean @default(false)

  configs        LeaveConfiguration[]
  requests       LeaveRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
}

enum LeaveConfigGender {
  ALL
  MALE
  FEMALE
  OTHER
}

model LeaveConfiguration {
  id Int @id @default(autoincrement())

  leaveTypeId Int
  leaveType   LeaveType @relation(fields: [leaveTypeId], references: [id])

  monthlyLimit Float?
  yearlyLimit  Float?
  
  gender       LeaveConfigGender // ALL, MALE, FEMALE
  
  canCarryForward Boolean @default(false)
  maxConsecutiveDays Int?

  companyId Int
  company   Company @relation(fields: [companyId], references: [id])

  isActive  Boolean @default(true)
  version   Int     @default(1)
  isDeleted Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, leaveTypeId])
}

model LeaveRequest {
  id Int @id @default(autoincrement())

  userId Int
  user   User @relation(fields: [userId], references: [id])

  leaveTypeId Int
  leaveType   LeaveType @relation(fields: [leaveTypeId], references: [id])

  startDate DateTime
  endDate   DateTime
  daysCount Float

  reason String?
  status LeaveRequestStatus @default(PENDING)

  approvedById Int?
  approvedBy   User? @relation("ApprovedLeaves", fields: [approvedById], references: [id])

  companyId Int
  company   Company @relation(fields: [companyId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, companyId])
}


model PermissionRequest {
  id Int @id @default(autoincrement())

  userId Int
  user   User @relation(fields: [userId], references: [id])

  date      DateTime
  startTime String   // "09:00"
  endTime   String   // "11:00"
  hours     Float

  reason String?
  status LeaveRequestStatus @default(PENDING)

  companyId Int
  company   Company @relation(fields: [companyId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, companyId, date])
}

model PermissionConfiguration {
  id Int @id @default(autoincrement())

  monthlyLimit          Int   @default(2)
  maxMinutesPerPermission Float @default(120)

  companyId Int
  company   Company @relation(fields: [companyId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
}
